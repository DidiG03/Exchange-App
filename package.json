{
  "name": "exchange-bureau",
  "version": "1.0.2",
  "description": "Currency exchange bureau desktop app for Albania",
  "main": "./out/main/index.js",
  "author": "Exchange Bureau",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/DidiG03/Exchange-App.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win",
    "dist:publish": "npm run build && electron-builder --win --publish always",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.3",
    "node-thermal-printer": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "optionalDependencies": {
    "@thesusheer/electron-printer": "^2.0.4"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.exchangebureau.albania",
    "productName": "Exchange Bureau",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "icon": "icon.png",
    "artifactName": "Exchange-Bureau-Setup-${version}.${ext}",
    "files": [
      "out/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "DidiG03",
      "repo": "Exchange-App"
    }
  }
}
